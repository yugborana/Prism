# ─────────────────────────────────────────────────────────────────────────────
# Prism AI Code Reviewer — Environment Configuration
# Copy to .env: cp .env.example .env
# NEVER commit a real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# IMPORTANT: In AWS/Production, set to "production" to disable SQL echoing
# which would otherwise leak database records into CloudWatch logs.
ENVIRONMENT=development                    # development | staging | production

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# Permissions: Pull Requests (Read & Write), Contents (Read), Metadata (Read)
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=prism-reviewer
GITHUB_APP_PRIVATE_KEY_PATH=./keys/github-app.pem   # Local dev: path to PEM file
# GITHUB_APP_PRIVATE_KEY=                            # Production: PEM content injected from AWS Secrets Manager
GITHUB_TOKEN=                                        # PAT fallback for local testing only (not used in production)


# ── LLM Providers ────────────────────────────────────────────────
# Default provider (gemini, openai, anthropic, groq, bedrock, ollama, litellm)
LLM_PROVIDER=litellm

# API Keys (passed to LiteLLM gateway container)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# AWS (for Bedrock fallback + Secrets Manager)
AWS_REGION=us-east-1

# ── Vector Database (Qdrant) ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                            # Leave empty for local Qdrant

# ── PostgreSQL (Audit Trail) ─────────────────────────────────────────────────
# WARNING: Do not use default prism:prism in production!
# For AWS deployment, use RDS and store credentials in AWS Secrets Manager.
DATABASE_URL=postgresql+asyncpg://prism:prism@host.docker.internal:5432/prism

# ── Redis ─────────────────────────────────────────────────────────────────────
# For AWS deployment, use ElastiCache with an AUTH token.
REDIS_URL=redis://localhost:6379/0

# ── API Authentication ────────────────────────────────────────────────────────
# IMPORTANT: API key for internal endpoints (/test-review, /dashboards, /alerts).
# If left empty, internal endpoints are UNAUTHENTICATED (development only).
# On AWS, generate a strong random string and set this.
PRISM_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Monitoring Integrations ──────────────────────────────────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_HOST=api.datadoghq.com
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
TEMP_REPO_DIR=./temp_repos
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Repo Indexing (Cursor-style codebase indexing) ───────────────────────────
# Max files to index per repo — repos exceeding this are skipped (monorepo guard)
REPO_INDEX_MAX_FILES=5000
# Auto-cleanup repo clones older than this (hours)
REPO_CLONE_MAX_AGE_HOURS=24
# Embedding cache TTL in seconds (7 days) — unchanged chunks skip re-embedding
CHUNK_EMBEDDING_CACHE_TTL=604800
# SimHash similarity threshold — Hamming distance out of 256 bits
# Lower = stricter matching, 25 = ~90% file overlap required for index reuse
SIMHASH_SIMILARITY_THRESHOLD=25
# Index TTL — repos not updated in this many days have their index deleted
REPO_INDEX_TTL_DAYS=30

# ── Cloudflare Tunnel (production only) ──────────────────────────────────────
TUNNEL_TOKEN=
