# ─────────────────────────────────────────────────────────────────────────────
# Prism AI Code Reviewer — Environment Configuration
# Copy to .env: cp .env.example .env
# NEVER commit a real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# IMPORTANT: In AWS/Production, set to "production" to disable SQL echoing
# which would otherwise leak database records into CloudWatch logs.
ENVIRONMENT=development                    # development | staging | production

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# Permissions: Pull Requests (Read & Write), Contents (Read), Metadata (Read)
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=prism-reviewer
GITHUB_APP_PRIVATE_KEY_PATH=./keys/github-app.pem
GITHUB_TOKEN=                              # Personal Access Token for API fallback

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which provider to use: ollama | gemini | openai | anthropic | groq | bedrock
LLM_PROVIDER=groq

# API Keys (only the one for your chosen provider is required)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS (only for Bedrock)
AWS_REGION=us-east-1

# ── Model Names (optional — defaults are set in config.py) ───────────────────
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local models)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder:7b

# ── Vector Database (Qdrant) ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                            # Leave empty for local Qdrant

# ── PostgreSQL (Audit Trail) ─────────────────────────────────────────────────
# WARNING: Do not use default prism:prism in production!
# For AWS deployment, use RDS and store credentials in AWS Secrets Manager.
DATABASE_URL=postgresql+asyncpg://prism:prism@localhost:5432/prism

# ── Redis ─────────────────────────────────────────────────────────────────────
# For AWS deployment, use ElastiCache with an AUTH token.
REDIS_URL=redis://localhost:6379/0

# ── API Authentication ────────────────────────────────────────────────────────
# IMPORTANT: API key for internal endpoints (/test-review, /dashboards, /alerts).
# If left empty, internal endpoints are UNAUTHENTICATED (development only).
# On AWS, generate a strong random string and set this.
PRISM_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_ENDPOINT=http://localhost:4317
LOG_LEVEL=info
PROMETHEUS_PORT_API=9091
PROMETHEUS_PORT_WORKER=9092

# ── Monitoring Integrations ──────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_HOST=api.datadoghq.com
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
TEMP_REPO_DIR=./temp_repos
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Cloudflare Tunnel (production only) ──────────────────────────────────────
TUNNEL_TOKEN=
