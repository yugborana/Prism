{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Reviews In Flight",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "prism_reviews_in_flight", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Reviews (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "increase(prism_review_total[24h])", "refId": "A" }]
    },
    {
      "title": "Review Success Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(prism_review_total{status=\"completed\"}[1h])) / sum(rate(prism_review_total[1h])) * 100", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Avg Review Duration",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.50, rate(prism_review_duration_seconds_bucket[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Review Pipeline Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(prism_review_duration_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(prism_review_duration_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(prism_review_duration_seconds_bucket[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "title": "Agent Task Duration by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(prism_agent_task_duration_seconds_bucket[5m])) > 0", "legendFormat": "{{agent}} p95", "refId": "A" }
      ]
    },
    {
      "title": "Findings by Severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "targets": [{ "expr": "sum by (severity) (prism_findings_total)", "legendFormat": "{{severity}}", "refId": "A" }]
    },
    {
      "title": "Findings by Agent",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "targets": [{ "expr": "sum by (agent) (prism_findings_total)", "legendFormat": "{{agent}}", "refId": "A" }]
    },
    {
      "title": "LLM Latency by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(prism_llm_latency_seconds_bucket[5m])) > 0", "legendFormat": "{{model}} p95", "refId": "A" }
      ]
    },
    {
      "title": "LLM Calls Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "sum by (status) (rate(prism_llm_calls_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "title": "Webhook Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "sum by (status) (rate(prism_webhook_requests_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "title": "System Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "targets": [
        { "expr": "sum by (component) (rate(prism_system_errors_total[5m]))", "legendFormat": "{{component}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["prism", "code-review"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "Prism Code Review Dashboard",
  "uid": "prism-review-dashboard",
  "version": 1
}
